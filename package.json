{
  "name": "chronicle-backend",
  "version": "1.0.0",
  "description": "Chronicle Task Manager — Production-ready REST API (Node 22 + Express + MongoDB/Mongoose)",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=22.15.0"
  },
  
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js --trace-warnings",
    "lint": "eslint src/**/*.js",
    "test": "jest --runInBand --forceExit",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.4.1",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.0.0"
  },
  "keywords": [
    "chronicle",
    "tasks",
    "todo",
    "express",
    "mongodb",
    "rest-api"
  ],
  "license": "MIT",
  "nodemonConfig": {
    "ext": "js",
    "ignore": ["logs/*", "node_modules/*"]
  }
}
