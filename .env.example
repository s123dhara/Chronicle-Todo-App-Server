# ── Server Configuration ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ──────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/chronicle
# For MongoDB Atlas:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/chronicle

# ── JWT Secrets (REQUIRED - Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ───
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret_min_64_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── Security ──────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# For production, add your frontend URL:
# CORS_ORIGINS=https://your-frontend-url.vercel.app,http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
