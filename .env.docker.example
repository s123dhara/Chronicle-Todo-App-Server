# Docker Environment Variables
# Copy this file to .env.docker and fill in your values

# JWT Secrets (Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_64_character_random_secret_here
JWT_REFRESH_SECRET=your_64_character_random_refresh_secret_here

# MongoDB (if using external MongoDB instead of Docker MongoDB)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/chronicle

# Optional: Change default ports
# BACKEND_PORT=5000
# FRONTEND_PORT=80
# MONGODB_PORT=27017
